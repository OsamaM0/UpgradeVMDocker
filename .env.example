# ==========================================================================
#  Odoo 18 — environment configuration
#  Copy to .env (never commit .env). scripts/setup-vps.sh fills the secrets
#  marked "change_me_*" with strong random values automatically.
# ==========================================================================

# ---- Project / deployment ----
PROJECT_NAME=odoo18
DOMAIN=odoo.example.com

# ---- Odoo ----
ODOO_PORT=8069                 # localhost-only bind (127.0.0.1) for SSH-tunnel dev access
ODOO_WORKERS=2                 # 0 = single-process; raise for more CPU cores
LIST_DB=True                   # set False in production to hide the DB manager
ODOO_ADMIN_PASSWD=change_me_master_password

# ---- PostgreSQL ----
POSTGRES_USER=odoo
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=odoo18
POSTGRES_PORT=5432             # localhost-only bind (127.0.0.1)

# ---- Addons ----
# Comma-separated paths INSIDE the container. /mnt/extra-addons == ./addons
ADDONS_PATH=/mnt/extra-addons

# ==========================================================================
#  Remote database source — fill in LATER (used by scripts/restore-db.sh)
#  Nothing here is required to boot the stack; provide when ready to import.
# ==========================================================================
REMOTE_HOST=                   # e.g. 203.0.113.10  (live/production VPS IP)
REMOTE_SSH_USER=               # e.g. deploy
REMOTE_SSH_PORT=22
# Use ONE auth method:
REMOTE_SSH_KEY=                # e.g. /root/.ssh/id_ed25519   (preferred)
REMOTE_SSH_PASSWORD=           # requires sshpass             (less secure)
REMOTE_DUMP_PATH=              # e.g. /var/backups/odoo/live.dump
LOCAL_DUMP_PATH=./backups
TARGET_DB=odoo18
