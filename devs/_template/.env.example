# ==========================================================================
#  Developer VM instance configuration — copy of devs/_template/.env.example.
#  Every developer instance needs UNIQUE: PROJECT_NAME, DOMAIN, SSH_PORT,
#  ODOO_PORT, POSTGRES_PORT, POSTGRES_USER/DB. Never reuse ports across devs.
# ==========================================================================

# ---- Instance identity ----
PROJECT_NAME=devN
DOMAIN=devN.example.com          # DNS A record -> VPS IP; Traefik issues HTTPS for this host

# ---- SSH ("the VM" — PyCharm / VS Code Remote-SSH connect here) ----
SSH_PORT=22NN                    # unique public port, key-only auth
DEV_USER=developer
DEV_SSH_PUBLIC_KEY=              # paste one public key inline, OR put it in ssh/authorized_keys

# ---- Odoo ----
ODOO_PORT=1NNNN                  # 127.0.0.1-only; reach via: ssh -p SSH_PORT -L 8069:127.0.0.1:ODOO_PORT ...
ODOO_WORKERS=0                   # 0 = single-process, easiest to debug
LIST_DB=True
ODOO_ADMIN_PASSWD=change_me_master_password

# ---- PostgreSQL ----
POSTGRES_USER=devN
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=devN
POSTGRES_PORT=1NNNN               # 127.0.0.1-only; reach via SSH tunnel through SSH_PORT above

# ---- Addons (this developer's own isolated addons only) ----
ADDONS_PATH=/mnt/extra-addons
