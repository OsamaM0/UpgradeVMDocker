# ==========================================================================
#  dev2 — Developer VM instance configuration
#  Copy to .env (never commit .env) and fill in real secrets.
# ==========================================================================

# ---- Instance identity ----
PROJECT_NAME=dev2
DOMAIN=dev2.example.com          # DNS A record -> VPS IP; Traefik issues HTTPS for this host

# ---- SSH ("the VM" — PyCharm / VS Code Remote-SSH connect here) ----
SSH_PORT=2202                    # unique public port, key-only auth
DEV_USER=developer
DEV_SSH_PUBLIC_KEY=              # paste one public key inline, OR put it in ssh/authorized_keys

# ---- Odoo ----
ODOO_PORT=18070                  # 127.0.0.1-only; reach via: ssh -p 2202 -L 8069:127.0.0.1:18070 developer@VPS_IP
ODOO_WORKERS=0                   # 0 = single-process, easiest to debug
LIST_DB=True
ODOO_ADMIN_PASSWD=change_me_master_password

# ---- PostgreSQL ----
POSTGRES_USER=dev2
POSTGRES_PASSWORD=change_me_db_password
POSTGRES_DB=dev2
POSTGRES_PORT=15433               # 127.0.0.1-only; reach via SSH tunnel through SSH_PORT above

# ---- Addons (this developer's own isolated addons only) ----
ADDONS_PATH=/mnt/extra-addons
